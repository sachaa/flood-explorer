# Google Earth Engine service account credentials
# Option 1: Service account (recommended)
#   - Go to https://console.cloud.google.com/apis/credentials
#   - Create a service account, download JSON key
#   - Name it 'ee-service-account.json' and place it in this directory
#   - Register the service account at https://signup.earthengine.google.com
#
# Option 2: Personal OAuth
#   - On first run, you'll be prompted to authenticate in the browser
#   - The earthengine CLI will cache your credentials

# Coordinates for the area of interest (Escobar, Paraguarí, Paraguay)
CENTER_LAT=-25.634
CENTER_LON=-57.072
ZOOM_START=13
